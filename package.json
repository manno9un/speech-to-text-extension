{
  "name": "speech-to-text-extension",
  "version": "0.1.0",
  "description": "Convert speech to text for any web input field using Web Speech API",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:main": "vite build",
    "build:content": "vite build --config vite.content.config.ts",
    "build:background": "vite build --config vite.background.config.ts",
    "build:assets": "node scripts/copy-assets.js",
    "build": "npm run build:main && npm run build:content && npm run build:background && npm run build:assets",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "echo 'Linting not configured yet'"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@types/chrome": "^0.0.240",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^29.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "vite": "^4.5.0"
  },
  "keywords": [
    "chrome-extension",
    "speech-to-text",
    "web-speech-api",
    "voice-input"
  ],
  "author": "Your Name",
  "license": "MIT"
}
